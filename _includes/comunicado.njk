---
layout: base.njk
---
<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">Inicio</a> / <a href="/#comunicados">Comunicados</a> / {{ title }}</div>
    <span class="eyebrow">Comunicado oficial</span>
    <h1>{{ title }}</h1>
  </div>
</section>

<section>
  <div class="container comunicado-detail">
    <a href="/#comunicados" class="back-link">← Volver a comunicados</a>
    <p class="meta-date">Publicado el {{ fecha_inicio | fecha }}</p>
    <div class="content">
      {{ content | safe }}
    </div>
    {% if documentos and documentos.length %}
    <div class="docs-adjuntos">
      <h2>Documentos adjuntos</h2>
      {% for doc in documentos %}
      <p class="doc-download"><a href="{{ doc }}" class="btn btn-primary" target="_blank" rel="noopener">📄 {{ doc | basename }}</a></p>
      {% endfor %}
    </div>
    {% endif %}
    <div class="share-row">¿Tienes información adicional sobre este asunto? <a href="/contacto.html">Escríbenos</a>.</div>
  </div>
</section>
