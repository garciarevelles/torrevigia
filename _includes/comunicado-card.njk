<article class="comunicado-card">
  <div class="comunicado-date"><span class="day">{{ comunicado.data.fecha_inicio | dia }}</span><span class="mes">{{ comunicado.data.fecha_inicio | mmAaaa }}</span></div>
  <div class="comunicado-body">
    <h3><a href="{{ comunicado.url }}">{{ comunicado.data.title }}</a></h3>
    <a href="{{ comunicado.url }}" class="news-link">Leer comunicado completo →</a>
  </div>
</article>
